# GitHub Pages 部署配置
# 复制此文件为 .env.production 并修改实际值

# 仓库名称（GitHub Pages 部署路径）
# 部署到 username.github.io/stock-chanlun 时使用下方默认值
VITE_BASE_URL=/stock-chanlun/

# 后端 API 根路径（必填）
# 可只填源站域名（会自动补 /api），或填完整前缀（须以 /api 结尾）
# 示例：
#   VITE_API_BASE_URL=https://stock-chanlun.up.railway.app
#   VITE_API_BASE_URL=https://xxx.railway.app/api
VITE_API_BASE_URL=https://your-backend.railway.app
