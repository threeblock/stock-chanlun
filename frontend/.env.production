# GitHub Pages 部署配置
# 复制此文件为 .env.production 并修改实际值

# 仓库名称（GitHub Pages 部署路径）
# 如果部署到 username.github.io 根目录，设置为 "/"
# 如果部署到子路径如 username.github.io/stock-chanlun，设置为 "/stock-chanlun/"
VITE_BASE_URL=/

# 后端 API 地址（必填，修改为实际后端服务地址）
# 推荐后端部署平台：Railway / Render / Fly.io / Railway
# 示例：
#   Railway:  https://stock-chanlun.up.railway.app
#   Render:   https://stock-chanlun.onrender.com
#   Fly.io:   https://stock-chanlun.fly.dev
VITE_API_BASE_URL=https://your-backend.railway.app
